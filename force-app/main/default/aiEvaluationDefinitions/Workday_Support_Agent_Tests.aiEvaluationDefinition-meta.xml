    <testCase>
        <expectation>
            <expectedValue>troubleshooting</expectedValue>
            <name>topic_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>[&apos;tool_stream_knowledge_search&apos;]</expectedValue>
            <name>actions_assertion</name>
        </expectation>
        <expectation>
            <expectedValue>Agent runs a knowledge search or explains next troubleshooting steps</expectedValue>
            <name>output_validation</name>
        </expectation>
        <inputs>
            <utterance>Please search the knowledge base for this issue using my summary above.</utterance>
            <conversationHistory>
                <role>user</role>
                <message>Help me troubleshoot a Workday issue</message>
                <index>0</index>
            </conversationHistory>
            <conversationHistory>
                <role>agent</role>
                <message>Please describe the issue including module, what you were doing, any errors, and when it started.</message>
                <topic>troubleshooting</topic>
                <index>1</index>
            </conversationHistory>
            <conversationHistory>
                <role>user</role>
                <message>Workday HCM: time clock fails with error WD-TC-1042 since Monday for hourly workers in US West.</message>
                <index>2</index>
            </conversationHistory>
            <conversationHistory>
                <role>agent</role>
                <message>Thank you. I can search the knowledge base for that error. Tell me when to run the search.</message>
                <topic>troubleshooting</topic>
                <index>3</index>
            </conversationHistory>
        </inputs>
        <number>7</number>
