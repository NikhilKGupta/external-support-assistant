system:
    instructions: "You are the Workday Support Specialist for customer admins accessing via the community portal. You help Workday administrators troubleshoot issues and configure their internal HCM and ERP instances. EXPERTISE: Workday HCM, Financials, Payroll, Time Tracking, Integration debugging, Security groups and roles, Business process configuration, Reports and Prism Analytics, User and worker management. GUIDELINES: Address the admin by name once loaded. Use Workday-specific terminology. Search the knowledge base before concluding an issue is unresolved. Capture the Workday module and issue summary before searching or creating cases. Escalate for instance-specific data issues, security incidents, complex multi-system integrations, or when two KB searches have not resolved the issue. Always create a case before escalating so the specialist has full context."
    messages:
        welcome: "Welcome to Workday Customer Support! I am here to help you troubleshoot issues and configure your Workday instance. How can I assist you today?"
        error: "Sorry, something went wrong. Please try again."

config:
    developer_name: "Workday_Support_Agent"
    agent_type: "AgentforceServiceAgent"
    default_agent_user: "workday_support_agent@00DHu00000yNLTtMAO.ext"
    description: "Service agent for Workday customer admins via ESA_Deployment community portal. Handles troubleshooting and configuration with seamless case creation and zero-context escalation."

connection messaging:
    escalation_message: "Connecting you with a Workday support specialist now. They will have full context of our conversation and your case details."
    outbound_route_type: "OmniChannelFlow"
    outbound_route_name: "flow://Route_Workday_To_Queue"
    adaptive_response_allowed: False

variables:
    # Community portal authentication
    ContactId: linked string
        description: "Contact ID from the authenticated community portal session"
    admin_account_id: linked string
        description: "Account ID from the authenticated community portal session"
    RoutableId: linked string
        description: "Messaging Session ID for Omni-Channel routing"

    # Session identity
    admin_name: mutable string = ""
    support_tier: mutable string = ""

    # Issue classification
    issue_type: mutable string = ""
    workday_module: mutable string = ""
    issue_summary: mutable string = ""

    # Workflow state
    kb_search_performed: mutable boolean = False
    kb_articles_found: mutable number = 0
    escalation_needed: mutable boolean = False

    # Case tracking
    case_created: mutable boolean = False
    case_number: mutable string = ""
    predicted_priority: mutable string = ""
    predicted_product_area: mutable string = ""
    ai_summary: mutable string = ""
    ai_transcript: mutable string = ""

    # Escalation latch
    escalation_initiated: mutable boolean = False

language:
    default_locale: "en_US"
    additional_locales: ""
    all_additional_locales: False

start_agent topic_router:
    description: "Entry point that loads customer context and routes to troubleshooting or configuration"
    reasoning:
        instructions: ->
            run @actions.load_admin_context
                with contact_id = @variables.ContactId
                with account_id = @variables.admin_account_id
                set @variables.admin_name = @outputs.admin_name
                set @variables.support_tier = @outputs.support_tier

            if @variables.admin_name != "":
                | Welcome back, {!@variables.admin_name}!
            | I can assist you with:
            | - Troubleshoot: Diagnose and resolve issues with your Workday instance
            | - Configure: Step-by-step guidance for system setup and configuration
            |
            | What do you need help with today?

        actions:
            go_troubleshooting: @utils.transition to @topic.troubleshooting
                description: "Help me troubleshoot a Workday issue"

            go_configuration: @utils.transition to @topic.configuration_assistance
                description: "Help me configure something in Workday"

            go_escalation: @utils.transition to @topic.pre_escalation
                description: "I need to speak with a support specialist"

    actions:
        load_admin_context:
            description: "Load the customer admin profile and account details from the community portal session"
            inputs:
                contact_id: string
                account_id: string
            outputs:
                admin_name: string
                support_tier: string
                success: boolean
            target: "flow://Load_Workday_Customer_Context"

topic troubleshooting:
    description: "Diagnose and resolve Workday issues using the knowledge base; create cases when unresolvable"
    reasoning:
        instructions: ->
            | Please describe the Workday issue you are experiencing. Include:
            | - Which Workday module (HCM, Financials, Payroll, etc.)
            | - What you were trying to do when the issue occurred
            | - Any error messages you received
            | - When the issue started
            |
            | I will search our knowledge base for solutions. If the issue cannot be resolved,
            | I will create a support case and connect you with a specialist.

        actions:
            search_kb: @actions.search_knowledge_base
                description: "Search the knowledge base for a solution to this issue"
                available when @variables.issue_summary != ""

            log_case: @actions.summarize_conversation
                with "Input:Transcript" = @variables.issue_summary
                with "Input:Issue_Type" = @variables.issue_type
                with "Input:Workday_Module" = @variables.workday_module
                set @variables.ai_summary = @outputs.promptResponse
                set @variables.ai_transcript = @outputs.promptResponse
                run @actions.create_support_case
                    with contact_id = @variables.ContactId
                    with account_id = @variables.admin_account_id
                    with issue_summary = @variables.issue_summary
                    with issue_type = @variables.issue_type
                    with workday_module = @variables.workday_module
                    with ai_summary = @variables.ai_summary
                    with ai_transcript = @variables.ai_transcript
                    set @variables.case_number = @outputs.case_number
                    set @variables.predicted_priority = @outputs.predicted_priority
                    set @variables.predicted_product_area = @outputs.predicted_product_area
                    set @variables.case_created = True
                description: "Create a support case for tracking this issue"
                available when @variables.issue_summary != ""

            go_to_specialist: @utils.transition to @topic.pre_escalation
                description: "Connect me with a specialist"

            back_to_menu: @utils.transition to @topic.topic_router
                description: "Return to the main menu"

    actions:
        search_knowledge_base:
            description: "Search the Workday knowledge base for solutions to the reported issue"
            target: "generatePromptResponse://Workday_KB_Search"

        summarize_conversation:
            description: "Generate a structured conversation summary for zero-context handoff to the human specialist"
            inputs:
                "Input:Transcript": string
                    description: "Conversation transcript from the current session"
                "Input:Issue_Type": string
                    description: "Issue type category"
                "Input:Workday_Module": string
                    description: "Workday module affected"
            outputs:
                promptResponse: string
                    description: "Structured transcript summary for case handoff"
            target: "generatePromptResponse://Workday_Conversation_Summarizer"

        create_support_case:
            description: "Create a support case with AI summary for zero-context handoff when the issue cannot be resolved"
            inputs:
                contact_id: string
                account_id: string
                issue_summary: string
                issue_type: string
                workday_module: string
                ai_transcript: string
                ai_summary: string
            outputs:
                case_number: string
                case_id: string
                predicted_priority: string
                predicted_product_area: string
                success: boolean
            target: "flow://Create_Workday_Support_Case"

topic configuration_assistance:
    description: "Step-by-step configuration guidance for Workday modules with settings validation"
    reasoning:
        instructions: ->
            | I will guide you through configuring your Workday instance.
            |
            | What would you like to configure? Common areas include:
            | - Security groups and role assignments
            | - Business processes and approval workflows
            | - Reports and dashboards
            | - API integrations and connectors
            |
            | Please describe what you need to set up.

            if @variables.issue_type != "":
                | Let me retrieve the configuration guide for {!@variables.issue_type}...

        actions:
            get_guide: @actions.get_config_guide
                description: "Get step-by-step configuration guidance"
                available when @variables.issue_type != ""

            validate: @actions.validate_config
                with configType = @variables.issue_type
                with workdayModule = @variables.workday_module
                description: "Validate my configuration settings against best practices"
                available when @variables.issue_type != ""

            go_to_troubleshooting: @utils.transition to @topic.troubleshooting
                description: "I am encountering errors during the configuration"

            back_to_menu: @utils.transition to @topic.topic_router
                description: "Return to the main menu"

    actions:
        get_config_guide:
            description: "Retrieve step-by-step configuration guidance for the requested Workday feature"
            target: "generatePromptResponse://Workday_Config_Guide"

        validate_config:
            description: "Validate configuration settings against Workday best practices before applying"
            inputs:
                configType: string
                workdayModule: string
            outputs:
                isValid: boolean
                validationErrors: string
                recommendations: string
            target: "apex://WorkdayConfigValidator"

topic pre_escalation:
    description: "Summarise the conversation and create a case before transferring to a human agent"
    reasoning:
        instructions: ->
            | I am preparing a handoff summary and support case for the specialist.

            if @variables.case_created == False:
                run @actions.summarize_conversation
                    with "Input:Transcript" = @variables.issue_summary
                    with "Input:Issue_Type" = @variables.issue_type
                    with "Input:Workday_Module" = @variables.workday_module
                    set @variables.ai_summary = @outputs.promptResponse
                    set @variables.ai_transcript = @outputs.promptResponse

                run @actions.create_case_for_escalation
                    with contact_id = @variables.ContactId
                    with account_id = @variables.admin_account_id
                    with issue_summary = @variables.issue_summary
                    with issue_type = @variables.issue_type
                    with workday_module = @variables.workday_module
                    with ai_summary = @variables.ai_summary
                    with ai_transcript = @variables.ai_transcript
                    set @variables.case_number = @outputs.case_number
                    set @variables.predicted_priority = @outputs.predicted_priority
                    set @variables.predicted_product_area = @outputs.predicted_product_area
                    set @variables.case_created = True

            | I have prepared a support case for the specialist.
            |
            | Case Created: {!@variables.case_number}
            | Priority: {!@variables.predicted_priority} | Area: {!@variables.predicted_product_area}
            |
            | The specialist will have complete context of everything we discussed.
            | You will not need to repeat yourself.
            |
            | Connecting you now...

        actions:
            summarize: @actions.summarize_conversation
                description: "Generate conversation summary for the specialist"

            go_to_escalation: @utils.transition to @topic.escalation
                description: "Connect me with a specialist"

    actions:
        summarize_conversation:
            description: "Generate a structured conversation summary for zero-context handoff to the human specialist"
            inputs:
                "Input:Transcript": string
                    description: "Conversation transcript from the current session"
                "Input:Issue_Type": string
                    description: "Issue type category"
                "Input:Workday_Module": string
                    description: "Workday module affected"
            outputs:
                promptResponse: string
                    description: "Structured transcript summary for case handoff"
            target: "generatePromptResponse://Workday_Conversation_Summarizer"

        create_case_for_escalation:
            description: "Create a support case with full transcript and predicted fields before escalation"
            inputs:
                contact_id: string
                account_id: string
                issue_summary: string
                issue_type: string
                workday_module: string
                ai_transcript: string
                ai_summary: string
            outputs:
                case_number: string
                predicted_priority: string
                predicted_product_area: string
                success: boolean
            target: "flow://Create_Workday_Support_Case"

topic escalation:
    description: "Transfer the conversation to a human Workday support specialist via Omni-Channel"
    before_reasoning: ->
        set @variables.escalation_initiated = True
    reasoning:
        instructions: ->
            if @variables.escalation_initiated == True:
                | Transferring you to a Workday support specialist now. Please hold a moment...

        actions:
            handoff: @utils.escalate
                description: "Transfer to human Workday specialist"
                available when @variables.escalation_initiated == True

topic farewell:
    description: "Close the conversation gracefully when the issue is resolved"
    reasoning:
        instructions: ->
            | Thank you for contacting Workday Support!
            | If you need further assistance, feel free to start a new chat anytime.
            | Have a great day!
