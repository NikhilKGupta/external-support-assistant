<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Workday Support Agent access: Cases, Contacts, Accounts, Tasks, custom Workday fields, Apex actions, and Flows. NOTE: Enable Shield Encryption on AI_Transcript__c and AI_Summary__c in production.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Workday Support Agent Access</label>

    <!-- ── Object Permissions ─────────────────────────────────────────── -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Case</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Contact</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Account</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Task</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

    <!-- ── Field Permissions — Case standard fields ───────────────────── -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Type</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Priority</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Origin</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Status</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ── Field Permissions — Case custom fields ────────────────────── -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Workday_Module__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Case.Product_Area__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <!-- AI_Transcript__c and AI_Summary__c: written via Flow (system context).
         Agent user has read access only. Enable Shield Platform Encryption in production. -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Case.AI_Transcript__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Case.AI_Summary__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Case.Risk_Score__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Case.Risk_Level__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Case.Next_Best_Action__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Case.Last_Risk_Assessment__c</field>
        <readable>true</readable>
    </fieldPermissions>

    <!-- ── Apex Class Access ──────────────────────────────────────────── -->
    <classAccesses>
        <apexClass>WorkdayConfigValidator</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>CaseFieldPredictor</apexClass>
        <enabled>true</enabled>
    </classAccesses>

    <!-- ── Flow Access ────────────────────────────────────────────────── -->
    <flowAccesses>
        <enabled>true</enabled>
        <flow>Load_Workday_Customer_Context</flow>
    </flowAccesses>
    <flowAccesses>
        <enabled>true</enabled>
        <flow>Create_Workday_Support_Case</flow>
    </flowAccesses>
    <flowAccesses>
        <enabled>true</enabled>
        <flow>Route_Workday_To_Queue</flow>
    </flowAccesses>

    <!-- ── User Permissions ───────────────────────────────────────────── -->
    <userPermissions>
        <enabled>true</enabled>
        <name>ApiEnabled</name>
    </userPermissions>
    <userPermissions>
        <enabled>true</enabled>
        <name>RunFlow</name>
    </userPermissions>
</PermissionSet>
